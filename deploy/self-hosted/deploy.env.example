# ---------------------------------------------------------------------------
# LibreChat self-hosted deployment environment.
#
# Copy this file to `.env`, fill in secrets and real domains, then run:
#
#   docker compose -f compose.yml up -d
#
# Generate secrets with:
#
#   openssl rand -hex 32
#   openssl rand -hex 16
# ---------------------------------------------------------------------------

# Public URLs
DOMAIN_CLIENT=https://chat.example.com
DOMAIN_SERVER=https://chat.example.com
LIBRECHAT_SITE_ADDRESS=https://chat.example.com
LIBRECHAT_ADMIN_ADDRESS=https://admin.example.com
ADMIN_PANEL_URL=https://admin.example.com

# Use these only for local HTTP testing.
# DOMAIN_CLIENT=http://localhost
# DOMAIN_SERVER=http://localhost
# LIBRECHAT_SITE_ADDRESS=http://localhost
# LIBRECHAT_ADMIN_ADDRESS=http://admin.localhost
# ADMIN_PANEL_URL=http://admin.localhost
# SESSION_COOKIE_SECURE=false
# ADMIN_PANEL_SESSION_COOKIE_SECURE=false

# Published self-host images
LIBRECHAT_API_IMAGE=registry.acceled.net/team/max/librechat-api
LIBRECHAT_API_IMAGE_TAG=main

# Core service settings
HOST=0.0.0.0
PORT=3080
TRUST_PROXY=1
NODE_ENV=production
NO_INDEX=true

# Caddy host ports
HTTP_PORT=80
HTTPS_PORT=443

# Required secrets. Replace every value before production use.
CREDS_KEY=replace_with_64_hex_chars
CREDS_IV=replace_with_32_hex_chars
JWT_SECRET=replace_with_64_hex_chars
JWT_REFRESH_SECRET=replace_with_64_hex_chars
MEILI_MASTER_KEY=replace_with_64_hex_chars
ADMIN_PANEL_SESSION_SECRET=replace_with_64_hex_chars

# Login and registration. For a private deployment, register the first account,
# then set ALLOW_REGISTRATION=false and restart.
ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true
ALLOW_UNVERIFIED_EMAIL_LOGIN=true
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false
ALLOW_PASSWORD_RESET=false

# Minimal endpoints for Agent chat backed by OpenAI or an OpenAI-compatible API.
ENDPOINTS=agents,openAI
OPENAI_API_KEY=replace_with_openai_or_gateway_key
# OPENAI_REVERSE_PROXY=https://your-openai-compatible-endpoint/v1
# OPENAI_MODELS=gpt-5-mini,gpt-4.1-mini,gpt-4o-mini

# Agent file search / RAG embeddings.
RAG_PORT=8000
RAG_OPENAI_API_KEY=${OPENAI_API_KEY}
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small
# RAG_OPENAI_BASEURL=https://your-openai-compatible-endpoint/v1
# RAG_USE_FULL_CONTEXT=false

# RAG vector database credentials. Change these before exposing backups or
# reusing the database outside this compose network.
RAG_POSTGRES_DB=librechat_rag
RAG_POSTGRES_USER=librechat_rag
RAG_POSTGRES_PASSWORD=replace_with_rag_postgres_password

# Optional outbound proxy for provider calls.
PROXY=
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=

# Optional logging knobs.
DEBUG_LOGGING=false
DEBUG_CONSOLE=false
LOG_TO_FILE=true
AGENT_DEBUG_LOGGING=false
